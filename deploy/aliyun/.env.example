# =============================================================================
# 阿里云 ECS（deploy/aliyun）— 复制为 .env 后填写，勿提交真实密钥
# =============================================================================
#
# 【生产环境】DATABASE_URL、SECRET_KEY 禁止留空！空值将导致连接失败或 JWT 不安全。
#
# 当前生产链路：阿里云后端通过 Railway AI Proxy 访问海外 AI 服务。
# 相关 Railway 项目：vibeclip-ai-proxy。
# S0-S5 中涉及外部 AI 的调用应优先走 AI_PROVIDER=railway_proxy + AI_PROXY_*。
#
# 安全提示：生产不建议把海外 AI 的真实密钥长期放在大陆 ECS；
# 密钥应放在 Railway Proxy 侧或后续专用 AI Gateway 侧。
#

# -----------------------------------------------------------------------------
# App / Deploy
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEPLOY_TARGET=aliyun
PUBLIC_SITE_URL=https://www.vibeclip.cn
API_BASE_URL=https://api.vibeclip.cn

PORT=8000
DEBUG=False

# -----------------------------------------------------------------------------
# 数据库（生产必须使用阿里云 RDS PostgreSQL；禁止留空 DATABASE_URL）
# -----------------------------------------------------------------------------
# 例：postgresql+psycopg2://user:pass@rm-xxxx.pg.rds.aliyuncs.com:5432/vibeclip
DATABASE_URL=

# JWT 等签名用强随机串（生产禁止留空）；本地模板可占位，上线前务必替换
SECRET_KEY=

# -----------------------------------------------------------------------------
# 站点与跨域（与模式 A 域名一致）
# -----------------------------------------------------------------------------
FRONTEND_ORIGIN=https://www.vibeclip.cn
FRONTEND_URL=https://www.vibeclip.cn
BACKEND_PUBLIC_BASE_URL=https://api.vibeclip.cn

# 须包含前端实际访问来源，否则浏览器报 CORS
CORS_ORIGINS=https://www.vibeclip.cn,https://vibeclip.cn,https://api.vibeclip.cn

# 短剧静态资源对外域名（通常与 API 同源）
PUBLIC_BASE_URL=https://api.vibeclip.cn
# SHORT_DRAMA_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# Storage（当前阶段 R2；OSS 仅占位）
# -----------------------------------------------------------------------------
# r2 = Cloudflare R2（S3 兼容）；oss = 未来阿里云 OSS（待接入）
STORAGE_PROVIDER=r2

R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# AI（生产推荐 Railway Proxy）
# -----------------------------------------------------------------------------
AI_PROVIDER=railway_proxy
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_PROXY_BASE_URL=
AI_PROXY_TOKEN=
AI_PROXY_TIMEOUT_SECONDS=120
STORY_GENERATION_PROXY_TIMEOUT_SECONDS=240
RAILWAY_IMAGE_PROXY_BASE_URL=
RAILWAY_IMAGE_PROXY_TIMEOUT_SECONDS=300

# direct_xai 备用配置；AI_PROVIDER=railway_proxy 时通常不在 ECS 侧填写真实 XAI_API_KEY
XAI_API_URL=https://api.x.ai/v1
XAI_API_KEY=
XAI_TEXT_MODEL=
XAI_STORY_MODEL=
XAI_STORY_MAX_OUTPUT_TOKENS=16384
XAI_VIDEO_MODEL=
XAI_BASE_URL=
XAI_VIDEO_BASE_URL=

SHORT_DRAMA_IMAGE_PROVIDER=xai
SHORT_DRAMA_USE_MOCK_IMAGE_PROVIDER=false
SHORT_DRAMA_USE_MOCK_VIDEO_PROVIDER=true

# -----------------------------------------------------------------------------
# Gemini（可选）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=

# -----------------------------------------------------------------------------
# OAuth（可选）
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# 支付（占位）
# -----------------------------------------------------------------------------
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# ALIPAY_NOTIFY_URL=
# ALIPAY_RETURN_URL=
# WECHAT_PAY_ENABLED=false
# WECHAT_PAY_APPID=
# WECHAT_PAY_MCHID=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_MCH_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY=
# WECHAT_PAY_NOTIFY_URL=
