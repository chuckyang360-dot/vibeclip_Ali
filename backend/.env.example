# =============================================================================
# App / Deploy
# =============================================================================
# development | staging | production
APP_ENV=development
# local | aliyun — 仅作部署标记，默认不改变运行时逻辑
APP_DEPLOY_TARGET=local

# =============================================================================
# API / Site URL（可选；文档与未来功能）
# =============================================================================
# 面向浏览器的站点根 URL，例如 https://www.vibeclip.cn
PUBLIC_SITE_URL=
# 对外 API 根 URL，例如 https://api.vibeclip.cn（支付异步通知仍优先用 ALIPAY_NOTIFY_URL / BACKEND_PUBLIC_BASE_URL）
API_BASE_URL=

# =============================================================================
# Storage Provider
# =============================================================================
# r2 = 当前 Cloudflare R2（S3 兼容，使用下方 R2_*）；oss = 未来阿里云 OSS（使用下方 OSS_* 占位项）
STORAGE_PROVIDER=r2

# =============================================================================
# Aliyun OSS（占位；STORAGE_PROVIDER=oss 且接入实现后再填，不影响当前 r2）
# =============================================================================
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# =============================================================================
# AI Provider
# =============================================================================
# direct_xai = 后端直接访问 xAI（与现有 XAI_* 一致）
# railway_proxy = 海外大模型统一走 Railway AI Proxy（须配置 AI_PROXY_*；模型与密钥在 Proxy 侧）
# gateway = 未来经境外 AI Gateway（使用 AI_GATEWAY_*；未实现前与缺失网关配置不影响 direct_xai）
AI_PROVIDER=direct_xai
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Railway AI Proxy（仅当 AI_PROVIDER=railway_proxy 时使用；根 URL，不含路径）
# AI_PROVIDER=railway_proxy
# AI_PROXY_BASE_URL=https://web-production-396bb6.up.railway.app
# AI_PROXY_TOKEN=
# AI_PROXY_TIMEOUT_SECONDS=120

PORT=8000
DEBUG=True
DATABASE_URL=sqlite:///./vibeclip.db
SECRET_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://vibeclip.vercel.app,https://vibeclip.cn,https://www.vibeclip.cn

# 当前过渡期模型配置，后续国内化会替换
XAI_API_KEY=
XAI_TEXT_MODEL=
# S2 Story Planner：留空则与 XAI_TEXT_MODEL / XAI_MODEL / 默认 grok-4.20 一致
XAI_STORY_MODEL=
XAI_STORY_MAX_OUTPUT_TOKENS=16384
XAI_VIDEO_MODEL=
SHORT_DRAMA_IMAGE_PROVIDER=mock
SHORT_DRAMA_USE_MOCK_IMAGE_PROVIDER=true
SHORT_DRAMA_USE_MOCK_VIDEO_PROVIDER=true

# 当前过渡期存储配置，后续替换阿里云 OSS
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# S1 产品图理解（Railway 由全局 AI_PROVIDER=railway_proxy 触发，勿再用 S1_VISION_PROVIDER=railway_proxy）
# S1_VISION_PROVIDER 仅保留 geoq = 旧 GeoQ 实验开关；留空则走 xAI 多模态（且 AI_PROVIDER 非 railway_proxy 时）
# -----------------------------------------------------------------------------
# S1_VISION_PROVIDER=geoq
# GEOQ_BASE_URL=https://api.geoq.help/v1
# GEOQ_API_KEY=
# GEOQ_S1_VISION_MODEL=gpt-image-2
# GEOQ_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# 以下为 app/config.py 中常见可选项示例（按需取消注释）
# -----------------------------------------------------------------------------

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Google Gemini（图片等）
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=

# 支付宝 / 微信支付
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# BACKEND_PUBLIC_BASE_URL=
# WECHAT_PAY_ENABLED=false
# WECHAT_PAY_APPID=
# WECHAT_PAY_MCHID=
