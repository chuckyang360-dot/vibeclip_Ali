# =============================================================================
# App / Deploy
# =============================================================================
# development | staging | production
APP_ENV=development
# local | aliyun — 仅作部署标记，默认不改变运行时逻辑
APP_DEPLOY_TARGET=local

# =============================================================================
# API / Site URL（可选；文档与未来功能）
# =============================================================================
# 面向浏览器的站点根 URL，例如 https://www.vibeclip.cn
PUBLIC_SITE_URL=
# 对外 API 根 URL，例如 https://api.vibeclip.cn（支付异步通知仍优先用 ALIPAY_NOTIFY_URL / BACKEND_PUBLIC_BASE_URL）
API_BASE_URL=

# =============================================================================
# Storage Provider
# =============================================================================
# r2 = 当前 Cloudflare R2（S3 兼容，使用下方 R2_*）；oss = 未来阿里云 OSS（使用下方 OSS_* 占位项）
STORAGE_PROVIDER=r2

# =============================================================================
# Aliyun OSS（占位；STORAGE_PROVIDER=oss 且接入实现后再填，不影响当前 r2）
# =============================================================================
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_PUBLIC_BASE_URL=

# =============================================================================
# AI Provider（文本 + S1 视觉 + S3 图片 路由）
# =============================================================================
# direct_xai     = 后端直连 xAI / Gemini（日志 provider=grok / xai_image direct=true）
# railway_proxy  = 经 Railway vibeclip-ai-proxy（须 AI_PROXY_BASE_URL + AI_PROXY_TOKEN）
# gateway        = 预留，未实现
#
# 注意：代码不读取 RAILWAY_PROXY_BASE_URL / RAILWAY_TEXT_PROXY_* / IMAGE_PROVIDER 等别名；
#       文本与 S1 视觉共用 AI_PROXY_*；图片另可读 RAILWAY_IMAGE_PROXY_*（见下）。
#
# 同一 Railway 服务上的路径（根 URL = AI_PROXY_BASE_URL，无尾斜杠）：
#   S1 产品图理解     POST {base}/s1/vision
#   结构化文本 S2 等  POST {base}/text/completions
#   S3 资产文生图     POST {base}/images/generations
#
# --- 方案 A：本地/阿里云与线上一致（Railway 中转）---
# AI_PROVIDER=railway_proxy
# AI_PROXY_BASE_URL=https://your-railway-proxy.example.com
# AI_PROXY_TOKEN=your-proxy-auth-token
# AI_PROXY_TIMEOUT_SECONDS=300
# RAILWAY_IMAGE_PROXY_BASE_URL=
# RAILWAY_IMAGE_PROXY_TIMEOUT_SECONDS=300
# SHORT_DRAMA_USE_MOCK_TEXT_PROVIDER=false
# SHORT_DRAMA_IMAGE_PROVIDER=xai
# SHORT_DRAMA_USE_MOCK_IMAGE_PROVIDER=false
#
# --- 方案 B：离线 mock（不调外部 AI）---
AI_PROVIDER=direct_xai
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AI_PROXY_BASE_URL=
AI_PROXY_TOKEN=
AI_PROXY_TIMEOUT_SECONDS=120
RAILWAY_IMAGE_PROXY_BASE_URL=
RAILWAY_IMAGE_PROXY_TIMEOUT_SECONDS=300

PORT=8000
DEBUG=True
DATABASE_URL=sqlite:///./vibeclip.db
SECRET_KEY=change-me
FRONTEND_ORIGIN=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://vibeclip.vercel.app,https://vibeclip.cn,https://www.vibeclip.cn

# xAI（direct_xai 时需要；railway_proxy 时模型名在 Proxy 侧配置，此处可留空）
XAI_API_KEY=
XAI_TEXT_MODEL=
XAI_STORY_MODEL=
XAI_STORY_MAX_OUTPUT_TOKENS=16384
XAI_VIDEO_MODEL=

# 短剧视频：mock | xai | seedance | railway_xai_proxy（显式 VIDEO_PROVIDER 优先于 SHORT_DRAMA_USE_MOCK_VIDEO_PROVIDER）
# 阿里云生产推荐：经 Railway 访问 xAI，backend 不直连 api.x.ai
# VIDEO_PROVIDER=railway_xai_proxy
# RAILWAY_XAI_VIDEO_PROXY_BASE_URL=https://your-railway-proxy.example.com
# RAILWAY_XAI_VIDEO_PROXY_TOKEN=  # 可与 AI_PROXY_TOKEN 相同
# RAILWAY_XAI_VIDEO_PROXY_TIMEOUT_SECONDS=600
# VIDEO_PROVIDER=seedance
# ARK_API_KEY=
# SEEDANCE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128
# SEEDANCE_GENERATE_AUDIO=true
# SEEDANCE_WATERMARK=false
# SEEDANCE_DEFAULT_RATIO=9:16
# SEEDANCE_TASK_POLL_INTERVAL_SECONDS=3
# SEEDANCE_TASK_TIMEOUT_SECONDS=600

# 短剧图片：xai | gemini | mock | railway_proxy
# 当 AI_PROVIDER=railway_proxy 且本项为 xai（默认）时，S3 自动走 Railway 图片代理，无需改为 railway_proxy
SHORT_DRAMA_IMAGE_PROVIDER=mock
SHORT_DRAMA_USE_MOCK_IMAGE_PROVIDER=true
# 最终视频生成本轮不改；本地可继续 mock
SHORT_DRAMA_USE_MOCK_VIDEO_PROVIDER=true
SHORT_DRAMA_USE_MOCK_TEXT_PROVIDER=false

# 当前过渡期存储配置，后续替换阿里云 OSS
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
PUBLIC_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# S1 产品图理解（Railway 由全局 AI_PROVIDER=railway_proxy 触发，勿再用 S1_VISION_PROVIDER=railway_proxy）
# S1_VISION_PROVIDER 仅保留 geoq = 旧 GeoQ 实验开关；留空则走 xAI 多模态（且 AI_PROVIDER 非 railway_proxy 时）
# -----------------------------------------------------------------------------
# S1_VISION_PROVIDER=geoq
# GEOQ_BASE_URL=https://api.geoq.help/v1
# GEOQ_API_KEY=
# GEOQ_S1_VISION_MODEL=gpt-image-2
# GEOQ_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# 以下为 app/config.py 中常见可选项示例（按需取消注释）
# -----------------------------------------------------------------------------

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Google Gemini（图片等）
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=

# 支付宝 / 微信支付
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
# BACKEND_PUBLIC_BASE_URL=
# WECHAT_PAY_ENABLED=false
# WECHAT_PAY_APPID=
# WECHAT_PAY_MCHID=
